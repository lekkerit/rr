# Google OAuth 2.0 Credentials
# Get these from Google Cloud Console > APIs & Services > Credentials

# OAuth 2.0 Client ID (ends with .apps.googleusercontent.com)
GOOGLE_CLIENT_ID=your_client_id_here.apps.googleusercontent.com

# OAuth 2.0 Client Secret
GOOGLE_CLIENT_SECRET=your_client_secret_here

# Redirect URI (must match Google Cloud Console configuration)
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/callback

# Google My Business API Configuration
GOOGLE_SCOPE=https://www.googleapis.com/auth/business.manage

# Server Configuration
PORT=3000
NODE_ENV=development

# Test Configuration
TEST_TIMEOUT=30000