        "options": {}
      },
      "id": "12",
      "name": "Update Review Status",
      "type": "n8n-nodes-base.airtable",
      "typeVersion": 2,
      "position": [2050, 450],
      "credentials": {
        "airtableTokenApi": {
          "id": "YOUR_AIRTABLE_CREDENTIALS",
          "name": "Airtable Personal Access Token"
        }
      }
    },
    {
      "parameters": {
        "authentication": "oAuth2",
        "operation": "create",
